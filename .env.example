# ──────────────────────────────────────────────────────────────
# .env.example — 環境変数のテンプレートファイル
# このファイルをコピーして .env を作成し、各値を設定してください。
# !! .env は Git に絶対コミットしないこと !!
# ──────────────────────────────────────────────────────────────

# ── データベース接続文字列 ──────────────────────────────────────
# 開発環境（SQLite）
DATABASE_URL=sqlite:///./cyberattack_dev.db
# 本番環境（PostgreSQL - Neon/Supabase 等のマネージドサービス）
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── API認証キー ────────────────────────────────────────────────
# 十分に長いランダム文字列を設定してください（例: openssl rand -hex 32）
API_KEY=your-secret-api-key-here

# ── 実行環境 ──────────────────────────────────────────────────
# development: Swagger UI 有効 / SQLite 使用
# production: Swagger UI 無効 / PostgreSQL 使用
ENVIRONMENT=development

# ── CISA KEV フィード URL（通常は変更不要）─────────────────────
CISA_KEV_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json

# ── クローラー実行時刻（UTC）──────────────────────────────────
# JST 04:00 = UTC 19:00 (前日)
CRON_HOUR_UTC=19
CRON_MINUTE_UTC=0
